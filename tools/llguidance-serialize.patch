+/// Serialize the tokenizer's token trie into a heap-allocated byte buffer.
+///
+/// On return `*dst_size` is set to the buffer length. Free the buffer with
+/// [`llg_free_bytes()`]. Pass the bytes to [`llg_new_tokenizer_from_bytes()`]
+/// to reconstruct a tokenizer without re-building the trie from the
+/// vocabulary. The encoding is native-endian: treat it as a
+/// same-architecture cache, not a portable interchange format.
+#[no_mangle]
+pub extern "C" fn llg_tokenizer_to_bytes(tok: &LlgTokenizer, dst_size: &mut usize) -> *mut u8 {
+    let trie_bytes = tok.tok_trie().to_bytes();
+    let slicer = tok.factory.slicer();
+    let slicer_bytes = if slicer.has_slices() {
+        slicer.to_bytes()
+    } else {
+        Vec::new()
+    };
+    let mut out = Vec::with_capacity(24 + trie_bytes.len() + slicer_bytes.len());
+    out.extend_from_slice(&LLG_SERIAL_MAGIC.to_le_bytes());
+    out.extend_from_slice(&1u32.to_le_bytes());
+    out.extend_from_slice(&(trie_bytes.len() as u64).to_le_bytes());
+    out.extend_from_slice(&trie_bytes);
+    out.extend_from_slice(&(slicer_bytes.len() as u64).to_le_bytes());
+    out.extend_from_slice(&slicer_bytes);
+    let boxed = out.into_boxed_slice();
+    *dst_size = boxed.len();
+    Box::into_raw(boxed) as *mut u8
+}
+
+/// Container magic for [`llg_tokenizer_to_bytes()`] output ("LLGC").
+const LLG_SERIAL_MAGIC: u32 = 0x434c_4c47;
+
+/// Split serialized tokenizer bytes into (trie, optional slicer) sections.
+/// Accepts both the v1 raw-trie format (TokTrie magic) and the container.
+fn split_serialized_tokenizer(bytes: &[u8]) -> Result<(&[u8], Option<&[u8]>)> {
+    ensure!(bytes.len() >= 4, "serialized tokenizer too short");
+    let magic = u32::from_le_bytes(bytes[0..4].try_into().unwrap());
+    if magic == TokTrie::SERIAL_MAGIC {
+        return Ok((bytes, None));
+    }
+    ensure!(magic == LLG_SERIAL_MAGIC, "bad serialized tokenizer magic");
+    ensure!(bytes.len() >= 16, "serialized tokenizer header truncated");
+    let version = u32::from_le_bytes(bytes[4..8].try_into().unwrap());
+    ensure!(version == 1, "unsupported serialized tokenizer version {version}");
+    let trie_len = u64::from_le_bytes(bytes[8..16].try_into().unwrap()) as usize;
+    ensure!(
+        trie_len <= bytes.len() && 16 + trie_len + 8 <= bytes.len(),
+        "serialized tokenizer trie section truncated"
+    );
+    let trie = &bytes[16..16 + trie_len];
+    let mut pos = 16 + trie_len;
+    let slicer_len =
+        u64::from_le_bytes(bytes[pos..pos + 8].try_into().unwrap()) as usize;
+    pos += 8;
+    ensure!(
+        slicer_len <= bytes.len() && pos + slicer_len == bytes.len(),
+        "serialized tokenizer slicer section truncated"
+    );
+    let slicer = if slicer_len > 0 {
+        Some(&bytes[pos..pos + slicer_len])
+    } else {
+        None
+    };
+    Ok((trie, slicer))
+}
+
+/// Free a buffer returned by [`llg_tokenizer_to_bytes()`].
+///
+/// # Safety
+/// `ptr` must have been returned by [`llg_tokenizer_to_bytes()`] and `size`
+/// must be the exact value written to `dst_size` by that call.
+#[no_mangle]
+pub unsafe extern "C" fn llg_free_bytes(ptr: *mut u8, size: usize) {
+    if !ptr.is_null() {
+        drop(Box::from_raw(std::ptr::slice_from_raw_parts_mut(ptr, size)));
+    }
+}
+
+/// Copy the caller's (possibly smaller, older-versioned) init struct into a
+/// zero-initialized local one, honoring its `struct_size` field.
+unsafe fn copy_tokenizer_init_v2(tok_init: *const LlgTokenizerInitV2) -> Result<LlgTokenizerInitV2> {
+    ensure!(!tok_init.is_null(), "tok_init is NULL");
+    let struct_size = std::ptr::read(tok_init as *const usize);
+    let min_size = std::mem::offset_of!(LlgTokenizerInitV2, token_lens);
+    ensure!(
+        struct_size >= min_size,
+        "LlgTokenizerInitV2.struct_size is {struct_size} but expected at least {min_size}. \
+         Set struct_size = sizeof(LlgTokenizerInitV2)."
+    );
+    let mut local: LlgTokenizerInitV2 = std::mem::zeroed();
+    let copy_size = std::cmp::min(struct_size, std::mem::size_of::<LlgTokenizerInitV2>());
+    std::ptr::copy_nonoverlapping(
+        tok_init as *const u8,
+        &mut local as *mut LlgTokenizerInitV2 as *mut u8,
+        copy_size,
+    );
+    Ok(local)
+}
+
+/// Create a tokenizer from trie bytes produced by [`llg_tokenizer_to_bytes()`].
+///
+/// The vocabulary fields of `tok_init` (`vocab_size`, `tok_eos`,
+/// `token_lens`, `token_bytes`, `tokenizer_json`, `tok_eos_extra*`) are
+/// ignored — the serialized trie already carries them. The
+/// `tokenize_fn` / `tokenize_user_data` / `tokenize_assumes_string` and
+/// `slices` fields are used exactly as in [`llg_new_tokenizer_v2()`].
+///
+/// Returns `NULL` on error (including corrupted trie bytes) and writes the
+/// message to `error_string`.
+///
+/// # Safety
+/// `trie_bytes` must point to `trie_bytes_len` readable bytes, and
+/// `tok_init` must satisfy the same contract as in [`llg_new_tokenizer_v2()`].
+#[no_mangle]
+pub unsafe extern "C" fn llg_new_tokenizer_from_bytes(
+    trie_bytes: *const u8,
+    trie_bytes_len: usize,
+    tok_init: *const LlgTokenizerInitV2,
+    error_string: *mut c_char,
+    error_string_len: usize,
+) -> *mut LlgTokenizer {
+    let result = crate::panic_utils::catch_unwind(std::panic::AssertUnwindSafe(|| {
+        let local = copy_tokenizer_init_v2(tok_init)?;
+        let bytes = slice_from_ptr(trie_bytes, trie_bytes_len)?;
+        let (trie_section, slicer_section) = split_serialized_tokenizer(bytes)?;
+        let trie = TokTrie::from_bytes(trie_section)?;
+        LlgTokenizer::from_trie_and_init(trie, &local, slicer_section)
+    }));
+    match result {
+        Ok(tok) => Box::into_raw(Box::new(tok)),
+        Err(e) => {
+            save_error_string(e, error_string, error_string_len);
+            std::ptr::null_mut()
+        }
+    }
+}
