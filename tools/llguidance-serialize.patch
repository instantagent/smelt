+
+// --- serialization (smelt: tools/llguidance-serialize.patch) ---------------
+// Bakes the *built* slicer — regex containment tree, per-slice masks, and
+// filtered sub-tries — so an embedder can reconstruct a ParserFactory
+// without paying the build cost (regex scans over the whole vocabulary
+// plus several trie rebuilds; ~0.65s on a 250k vocab).
+
+fn put_u64(out: &mut Vec<u8>, v: u64) {
+    out.extend_from_slice(&v.to_le_bytes());
+}
+
+fn put_section(out: &mut Vec<u8>, b: &[u8]) {
+    put_u64(out, b.len() as u64);
+    out.extend_from_slice(b);
+}
+
+fn get_u64(bytes: &[u8], pos: &mut usize) -> Result<u64> {
+    ensure!(*pos + 8 <= bytes.len(), "slicer bytes truncated");
+    let v = u64::from_le_bytes(bytes[*pos..*pos + 8].try_into().unwrap());
+    *pos += 8;
+    Ok(v)
+}
+
+fn get_section<'a>(bytes: &'a [u8], pos: &mut usize) -> Result<&'a [u8]> {
+    let len = usize::try_from(get_u64(bytes, pos)?)?;
+    ensure!(
+        len <= bytes.len() && *pos + len <= bytes.len(),
+        "slicer bytes truncated"
+    );
+    let r = &bytes[*pos..*pos + len];
+    *pos += len;
+    Ok(r)
+}
+
+fn put_vob(out: &mut Vec<u8>, v: &SimpleVob) {
+    put_u64(out, v.len() as u64);
+    let words = v.as_slice();
+    let mut b = Vec::with_capacity(words.len() * 4);
+    for w in words {
+        b.extend_from_slice(&w.to_le_bytes());
+    }
+    put_section(out, &b);
+}
+
+fn get_vob(bytes: &[u8], pos: &mut usize) -> Result<SimpleVob> {
+    let size = usize::try_from(get_u64(bytes, pos)?)?;
+    let raw = get_section(bytes, pos)?;
+    ensure!(raw.len() % 4 == 0, "slicer vob byte length not word-aligned");
+    let words: Vec<u32> = raw
+        .chunks_exact(4)
+        .map(|c| u32::from_le_bytes(c.try_into().unwrap()))
+        .collect();
+    ensure!(
+        words.len() == size.div_ceil(32),
+        "slicer vob length mismatch"
+    );
+    Ok(SimpleVob::from_raw_parts(words, size))
+}
+
+impl TokenizerSlice {
+    fn write_bytes(&self, out: &mut Vec<u8>) {
+        put_u64(out, self.idx as u64);
+        put_section(out, self.regex.as_bytes());
+        put_u64(out, self.trie_without_child.len() as u64);
+        for trie in &self.trie_without_child {
+            put_section(out, &trie.to_bytes());
+        }
+        put_section(out, &self.trie_without_children.to_bytes());
+        put_section(out, &self.trie_with_children.to_bytes());
+        put_vob(out, &self.mask_with_children);
+        put_vob(out, &self.mask_trimmed);
+        put_u64(out, self.children.len() as u64);
+        for child in &self.children {
+            child.write_bytes(out);
+        }
+    }
+
+    fn read_bytes(bytes: &[u8], pos: &mut usize, depth: usize) -> Result<Self> {
+        ensure!(depth < 64, "slicer tree too deep");
+        let idx = usize::try_from(get_u64(bytes, pos)?)?;
+        let regex = String::from_utf8(get_section(bytes, pos)?.to_vec())?;
+        let num_children = usize::try_from(get_u64(bytes, pos)?)?;
+        ensure!(num_children <= 1024, "slicer tree too wide");
+        let mut trie_without_child = Vec::with_capacity(num_children);
+        for _ in 0..num_children {
+            trie_without_child.push(TokTrie::from_bytes(get_section(bytes, pos)?)?);
+        }
+        let trie_without_children = TokTrie::from_bytes(get_section(bytes, pos)?)?;
+        let trie_with_children = TokTrie::from_bytes(get_section(bytes, pos)?)?;
+        let mask_with_children = get_vob(bytes, pos)?;
+        let mask_trimmed = get_vob(bytes, pos)?;
+        let trailer_children = usize::try_from(get_u64(bytes, pos)?)?;
+        ensure!(
+            trailer_children == num_children,
+            "slicer child count mismatch"
+        );
+        let mut children = Vec::with_capacity(num_children);
+        for _ in 0..num_children {
+            children.push(TokenizerSlice::read_bytes(bytes, pos, depth + 1)?);
+        }
+        Ok(TokenizerSlice {
+            idx,
+            regex,
+            trie_without_child,
+            trie_without_children,
+            trie_with_children,
+            mask_with_children,
+            mask_trimmed,
+            children,
+        })
+    }
+}
+
+impl SlicedBiasComputer {
+    const SERIAL_MAGIC: u64 = 0x534c_4352_0000_0001; // "SLCR" + version 1
+
+    /// Whether this slicer has any real slice regexes (an empty-slices
+    /// slicer is trivial to rebuild and not worth serializing).
+    pub fn has_slices(&self) -> bool {
+        !self.slice_regexes.is_empty()
+    }
+
+    /// Serialize the built slicer for [`SlicedBiasComputer::from_bytes`].
+    /// Native-endian trie payloads — a same-architecture cache, not a
+    /// portable interchange format.
+    pub fn to_bytes(&self) -> Vec<u8> {
+        let mut out = Vec::new();
+        put_u64(&mut out, Self::SERIAL_MAGIC);
+        put_u64(&mut out, self.slice_regexes.len() as u64);
+        for regex in &self.slice_regexes {
+            put_section(&mut out, regex.as_bytes());
+        }
+        self.top_slice.write_bytes(&mut out);
+        out
+    }
+
+    /// Reconstruct a slicer serialized by [`SlicedBiasComputer::to_bytes`].
+    pub fn from_bytes(tok_env: &TokEnv, bytes: &[u8]) -> Result<Self> {
+        let mut pos = 0;
+        ensure!(
+            get_u64(bytes, &mut pos)? == Self::SERIAL_MAGIC,
+            "bad slicer magic"
+        );
+        let num_regexes = usize::try_from(get_u64(bytes, &mut pos)?)?;
+        ensure!(num_regexes <= 1024, "too many slice regexes");
+        let mut slice_regexes = Vec::with_capacity(num_regexes);
+        for _ in 0..num_regexes {
+            slice_regexes.push(String::from_utf8(
+                get_section(bytes, &mut pos)?.to_vec(),
+            )?);
+        }
+        let top_slice = Arc::new(TokenizerSlice::read_bytes(bytes, &mut pos, 0)?);
+        ensure!(pos == bytes.len(), "trailing slicer bytes");
+        ensure!(
+            top_slice.trie_with_children.vocab_size()
+                == tok_env.tok_trie().vocab_size(),
+            "slicer vocab size does not match tokenizer"
+        );
+        Ok(SlicedBiasComputer {
+            top_slice,
+            slice_regexes,
+            tok_env: tok_env.clone(),
+        })
+    }
+}
+
+#[cfg(test)]
+mod serial_tests {
+    use super::*;
+    use crate::toktrie::ApproximateTokEnv;
+
+    #[test]
+    fn test_slicer_bytes_round_trip() {
+        let tok_env: TokEnv = ApproximateTokEnv::single_byte_env();
+        let slicer =
+            SlicedBiasComputer::new(&tok_env, &SlicedBiasComputer::json_slices())
+                .unwrap();
+        let bytes = slicer.to_bytes();
+        let restored = SlicedBiasComputer::from_bytes(&tok_env, &bytes).unwrap();
+        assert_eq!(restored.to_bytes(), bytes);
+        assert_eq!(restored.extra_lexemes(), slicer.extra_lexemes());
+    }
+
+    #[test]
+    fn test_slicer_from_bytes_rejects_corrupt() {
+        let tok_env: TokEnv = ApproximateTokEnv::single_byte_env();
+        let slicer =
+            SlicedBiasComputer::new(&tok_env, &SlicedBiasComputer::json_slices())
+                .unwrap();
+        let bytes = slicer.to_bytes();
+        assert!(SlicedBiasComputer::from_bytes(&tok_env, &bytes[..bytes.len() - 1])
+            .is_err());
+        let mut bad = bytes.clone();
+        bad[0] ^= 0xff;
+        assert!(SlicedBiasComputer::from_bytes(&tok_env, &bad).is_err());
+    }
+}
